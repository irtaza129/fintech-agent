# ===========================================
# LLM API KEYS (Choose one)
# ===========================================

# OpenAI (Recommended - GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Groq (Alternative - Free tier available)
GROQ_API_KEY=your_groq_api_key_here

# ===========================================
# LLM SETTINGS
# ===========================================

# Provider: "openai" or "groq"
LLM_PROVIDER=openai

# Model name
# For OpenAI: "gpt-4o-mini", "gpt-4o", "gpt-3.5-turbo"
# For Groq: "mixtral-8x7b-32768", "llama2-70b-4096"
LLM_MODEL=gpt-4o-mini

# Temperature (0.0-1.0) - Lower = more focused
LLM_TEMPERATURE=0.3

# Max tokens per response
LLM_MAX_TOKENS=1000

# ===========================================
# DATABASE
# ===========================================

DATABASE_URL=sqlite:///./fintech_agent.db

# ===========================================
# EMAIL SETTINGS
# ===========================================

# Enable/disable email sending
EMAIL_ENABLED=true

# SMTP Server (Gmail example)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Sender email and password
# For Gmail: Use App Password, not regular password
# https://support.google.com/accounts/answer/185833
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# ===========================================
# SCHEDULER SETTINGS
# ===========================================

# What time to run daily digest (24-hour format)
DIGEST_HOUR=7
DIGEST_MINUTE=0

# ===========================================
# API SETTINGS
# ===========================================

API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
